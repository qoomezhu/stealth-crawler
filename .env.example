# Environment
CRAWLER_API_KEY=dev-secret-change-me
CRAWLER_RATE_LIMIT_BACKEND=redis
CRAWLER_RATE_LIMIT_REQUESTS=60
CRAWLER_RATE_LIMIT_WINDOW=60
CRAWLER_RATE_LIMIT_REDIS_URL=redis://localhost:6379/0
CRAWLER_HTTP_TIMEOUT=60

# MCP Bridge -> upstream crawler API
CRAWLER_API_BASE_URL=http://localhost:8080

# MCP Bridge -> LLM / client auth
MCP_BEARER_TOKEN=dev-mcp-token-change-me
MCP_PUBLIC_PATHS=/healthz

# MCP transport mode
MCP_TRANSPORT=http
MCP_HOST=0.0.0.0
MCP_PORT=8001
